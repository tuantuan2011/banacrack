--- --- LOGIC TỰ ĐỘNG CẬP NHẬT (Ví dụ thực tế) --- ---

-- 1. Code đếm thời gian Uptime thực tế
local startTime = os.time()
task.spawn(function()
    while task.wait(1) do
        if not ScreenGui or not ScreenGui.Parent then break end
        local elapsed = os.time() - startTime
        local hours = math.floor(elapsed / 3600)
        local minutes = math.floor((elapsed % 3600) / 60)
        local seconds = elapsed % 60
        Stat_Uptime.Text = string.format("Uptime: %02d:%02d:%02d", hours, minutes, seconds)
    end
end)

-- 2. Logic ẩn/hiện khi bấm nút gạch dưới (_)
local isMinimized = false
MinimizeBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    ContentContainer.Visible = not isMinimized
    if isMinimized then
        MainFrame.Size = UDim2.new(0, 480, 0, 40) -- Thu nhỏ chỉ để lại thanh header
        MainStroke.Thickness = 1 -- Thu nhỏ viền lại chút cho đẹp
    else
        MainFrame.Size = UDim2.new(0, 480, 0, 310) -- Mở rộng lại bình thường
        MainStroke.Thickness = 1.5
    end
end)
